# GitHub App credentials
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=  # for local dev / Actions

# AWS
AWS_REGION=us-east-1
AWS_PROFILE=default  # local dev only; production uses OIDC role

# Bedrock model
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5-v1:0
BEDROCK_REGION=us-east-1

# MergeGuard config
MERGEGUARD_LOG_LEVEL=INFO
MERGEGUARD_CACHE_DIR=/tmp/mergeguard-cache
